# Application
NODE_ENV=production
PORT=3000                              # Overridden by the server at deploy time

# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Gmail (for sending order notifications and confirmation emails)
# Use an App Password, NOT your regular Gmail password.
# Create one at: https://myaccount.google.com/apppasswords
GMAIL_USER="your-gmail-address@gmail.com"
GMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"

# Recipient — who gets new order notifications
JO_EMAIL="jo@joscupcakes.com"

# Public site URL (used in email links)
SITE_URL="https://joscupcakes.com"
